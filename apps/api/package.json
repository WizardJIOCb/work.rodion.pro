{
  "name": "@work-rodion/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed-admin": "tsx src/scripts/seed-admin.ts",
    "auth:hash-password": "tsx src/scripts/hash-password.ts"
  },
  "dependencies": {
    "@work-rodion/shared": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.5",
    "express": "^4.21.2",
    "pg": "^8.16.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.15.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
